<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="detail-panel" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <VBox spacing="12">
  <padding>
    <Insets top="12" right="12" bottom="12" left="12" />
  </padding>

  <Label text="Student Details" styleClass="detail-panel-title" />
  <Label fx:id="emptyStateLabel" text="Select a student to view details." styleClass="detail-empty-state" wrapText="true" />

  <VBox fx:id="contentContainer" spacing="10" visible="false" managed="false">
    <VBox spacing="8" styleClass="detail-overview-card">
      <Label fx:id="nameLabel" styleClass="detail-name" text="Not set" />
      <GridPane hgap="10" vgap="6">
        <columnConstraints>
          <ColumnConstraints minWidth="110" />
          <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Next Session" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label fx:id="nextSessionSummaryLabel"
               styleClass="detail-summary-value"
               text="No upcoming sessions"
               wrapText="true"
               GridPane.columnIndex="1"
               GridPane.rowIndex="0" />

        <Label text="Attendance" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Label fx:id="attendanceSummaryLabel"
               styleClass="detail-summary-value"
               text="No attendance records"
               wrapText="true"
               GridPane.columnIndex="1"
               GridPane.rowIndex="1" />

        <Label text="Payment" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label fx:id="paymentStatusSummaryLabel"
               styleClass="detail-summary-value"
               text="No due date"
               wrapText="true"
               GridPane.columnIndex="1"
               GridPane.rowIndex="2" />
      </GridPane>
    </VBox>

    <HBox spacing="10" fillHeight="true">
      <VBox spacing="10" HBox.hgrow="ALWAYS">
        <VBox spacing="8" styleClass="detail-card">
          <Label text="Profile" styleClass="detail-group-title" />
          <GridPane hgap="10" vgap="6">
            <columnConstraints>
              <ColumnConstraints minWidth="110" />
              <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Phone" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="phoneLabel" styleClass="detail-field-value" text="Not set" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Email" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="emailLabel"
                   styleClass="detail-field-value"
                   text="Not set"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="1" />

            <Label text="Address" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="addressLabel"
                   styleClass="detail-field-value"
                   text="Not set"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="2" />

            <Label text="Parent Name" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="parentNameLabel"
                   styleClass="detail-field-value"
                   text="Not set"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="3" />

            <Label text="Parent Phone" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="parentPhoneLabel"
                   styleClass="detail-field-value"
                   text="Not set"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="4" />

            <Label text="Parent Email" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <Label fx:id="parentEmailLabel"
                   styleClass="detail-field-value"
                   text="Not set"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="5" />
          </GridPane>

          <VBox spacing="6">
            <Label text="Tags" styleClass="detail-section-title" />
            <FlowPane fx:id="tagsFlowPane" hgap="6" vgap="6" prefWrapLength="280" />
          </VBox>
        </VBox>

        <VBox spacing="8" styleClass="detail-card">
          <Label text="Academics" styleClass="detail-group-title" />

          <VBox spacing="6">
            <Label text="Subjects" styleClass="detail-section-title" />
            <FlowPane fx:id="subjectsFlowPane" hgap="6" vgap="6" prefWrapLength="280" />
          </VBox>

          <GridPane hgap="10" vgap="6">
            <columnConstraints>
              <ColumnConstraints minWidth="110" />
              <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Description" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="academicsNotesLabel"
                   styleClass="detail-field-value"
                   text="No description"
                   wrapText="true"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="0" />
          </GridPane>
        </VBox>
      </VBox>

      <VBox spacing="10" HBox.hgrow="ALWAYS">
        <VBox spacing="8" styleClass="detail-card" VBox.vgrow="ALWAYS">
          <Label text="Appointments &amp; Attendance" styleClass="detail-group-title" />
          <VBox fx:id="appointmentListContainer" spacing="6" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox spacing="8" styleClass="detail-card">
          <Label text="Payments" styleClass="detail-group-title" />
          <GridPane hgap="10" vgap="6">
            <columnConstraints>
              <ColumnConstraints minWidth="110" />
              <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Payment Due" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="paymentDueDateLabel" styleClass="detail-field-value" text="Not set" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Tuition Fees" styleClass="detail-field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="paymentAmountLabel" styleClass="detail-field-value" text="Not set" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          </GridPane>

          <VBox spacing="6">
            <Label text="Payment History" styleClass="detail-section-title" />
            <FlowPane fx:id="paymentHistoryFlowPane" hgap="6" vgap="6" prefWrapLength="280" />
            <Hyperlink fx:id="paymentHistoryToggleLink"
                       text="Show all"
                       visible="false"
                       managed="false"
                       focusTraversable="false"
                       styleClass="detail-toggle-link" />
          </VBox>
        </VBox>
      </VBox>
    </HBox>
  </VBox>
  </VBox>
</ScrollPane>
