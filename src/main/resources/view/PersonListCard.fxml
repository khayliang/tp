<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <VBox alignment="CENTER_LEFT" spacing="6" HBox.hgrow="ALWAYS" styleClass="person-card-content">
    <padding>
      <Insets top="8" right="10" bottom="8" left="10" />
    </padding>

    <HBox spacing="6" alignment="CENTER_LEFT">
      <Label fx:id="id" styleClass="person-index-label">
        <minWidth>
          <Region fx:constant="USE_PREF_SIZE" />
        </minWidth>
      </Label>
      <Label fx:id="name" text="\$first" styleClass="person-name-label" HBox.hgrow="ALWAYS" />
      <Label fx:id="paymentStatusLabel" text="No due date" styleClass="person-payment-chip" />
    </HBox>

    <FlowPane fx:id="summaryChips" hgap="6" vgap="4" prefWrapLength="320" />

    <Label fx:id="nextSessionLabel" text="Next: No upcoming sessions" styleClass="person-meta-label" wrapText="true" />
    <Label fx:id="attendanceLabel" text="Attendance: No records" styleClass="person-meta-secondary" wrapText="true" />
  </VBox>
</HBox>
